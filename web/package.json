{
  "name": "calcumaker-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Client-side browser emulator of Calcumaker 16 (real calcumaker-core via WASI).",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "npm run lint:ts && npm run lint:css",
    "lint:ts": "eslint . --max-warnings 0",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:fix": "eslint . --fix && stylelint \"src/**/*.css\" --fix",
    "build:wasm": "../scripts/build-wasm.sh",
    "verify:font": "node scripts/verify-font.mjs",
    "verify": "node scripts/verify-font.mjs && node scripts/verify-browser.mjs"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.0.0"
  }
}
